import cv2 as cv
import numpy as np
import matplotlib.pyplot as plt
from sklearn.linear_model import LinearRegression, RANSACRegressor
from google.colab import files
uploaded = files.upload()

# Replace with your filename
img = cv.imread('Fig 1-c.png', cv.IMREAD_GRAYSCALE)

edges = cv.Canny(img, 550, 690)

# Show images
plt.figure(figsize=(10,5))

plt.subplot(1,2,1)
plt.title("Original Image")
plt.imshow(img, cmap='gray')

plt.subplot(1,2,2)
plt.title("Canny Edge Detection")
plt.imshow(edges, cmap='gray')

plt.show()
indices = np.where(edges != 0)

x = indices[1]
y = indices[0]

# Stack data
data = np.vstack((x, y)).T

# Mean center
mean = np.mean(data, axis=0)
data_centered = data - mean

# SVD
U, S, Vt = np.linalg.svd(data_centered)

# Direction vector
direction = Vt[0]
slope_tls = direction[1] / direction[0]

# Line
x_line = np.linspace(min(x), max(x), 100)
y_line = slope_tls * (x_line - mean[0]) + mean[1]

# Plot
plt.figure(figsize=(6,6))
plt.scatter(x, y, s=1)
plt.plot(x_line, y_line, color='green', label="TLS Line")
plt.legend()
plt.gca().invert_yaxis()
plt.show()

# Angle
angle_tls = np.degrees(np.arctan(slope_tls))
print("TLS Angle:", angle_tls)
